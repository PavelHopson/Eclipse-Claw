# ============================================
# Eclipse Claw Configuration
# Copy to .env and fill in your values
# ============================================

# --- LLM Providers ---

# Ollama (local, default provider)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# OpenAI (optional cloud fallback)
# OPENAI_API_KEY   — set your OpenAI key
# OPENAI_BASE_URL  — defaults to https://api.openai.com/v1
# OPENAI_MODEL     — defaults to gpt-4o-mini

# Anthropic (optional cloud fallback)
# ANTHROPIC_API_KEY — set your Anthropic key
# ANTHROPIC_MODEL  — defaults to claude-sonnet-4-20250514

# --- Proxy ---

# Single proxy
# ECLIPSE_CLAW_PROXY=http://user:pass@host:port

# Proxy file (one per line: host:port:user:pass)
# ECLIPSE_CLAW_PROXY_FILE=/path/to/proxies.txt

# --- Server (eclipse-claw-server only) ---
# ECLIPSE_CLAW_PORT=3000
# ECLIPSE_CLAW_HOST=0.0.0.0
# ECLIPSE_CLAW_AUTH_KEY=your-auth-key
# ECLIPSE_CLAW_MAX_CONCURRENCY=50
# ECLIPSE_CLAW_JOB_TTL_SECS=3600
# ECLIPSE_CLAW_MAX_JOBS=100

# --- CLI LLM overrides ---
# ECLIPSE_CLAW_LLM_PROVIDER=ollama
# ECLIPSE_CLAW_LLM_MODEL=qwen3:8b
# ECLIPSE_CLAW_LLM_BASE_URL=http://localhost:11434

# --- Logging ---
# ECLIPSE_CLAW_LOG=info
